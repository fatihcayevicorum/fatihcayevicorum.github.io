rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isFatihAdmin() {
      return request.auth != null
        && request.auth.uid == 'obuZLQXuPAWsHE20bZxcAxCNsO02';
    }

    match /publicTea/status {
      allow read: if true;
      allow write: if isFatihAdmin();
    }

    match /adminTea/{document} {
      allow read, write: if isFatihAdmin();
    }

    match /publicMenu/catalog {
      allow read: if true;
      allow write: if isFatihAdmin();
    }

    match /adminStockItems/{document} {
      allow read, write: if isFatihAdmin();
    }

    match /adminStockMovements/{document} {
      allow read, write: if isFatihAdmin();
    }

    match /adminCreditCustomers/{document} {
      allow read, write: if isFatihAdmin();
    }

    match /adminCreditMovements/{document} {
      allow read, write: if isFatihAdmin();
    }

    match /adminAppSettings/{document} {
      allow read, write: if isFatihAdmin();
    }

    match /adminOrders/{document} {
      allow read, write: if isFatihAdmin();
    }

    match /adminSales/{document} {
      allow read, write: if isFatihAdmin();
    }

    match /adminDailyClosings/{document} {
      allow read, write: if isFatihAdmin();
    }

    function isActiveMerchant() {
      return request.auth != null
        && exists(/databases/$(database)/documents/merchantProfiles/$(request.auth.uid))
        && get(/databases/$(database)/documents/merchantProfiles/$(request.auth.uid)).data.active == true;
    }

    match /merchantProfiles/{merchantId} {
      allow read: if isFatihAdmin()
        || (request.auth != null && request.auth.uid == merchantId);
      allow create, update, delete: if isFatihAdmin();
    }

    match /merchantBalanceMovements/{movementId} {
      allow read: if isFatihAdmin()
        || (request.auth != null && resource.data.merchantId == request.auth.uid);
      allow create, update, delete: if isFatihAdmin();
    }

    match /merchantOrders/{orderId} {
      allow read: if isFatihAdmin()
        || (request.auth != null && resource.data.merchantId == request.auth.uid);
      allow create: if isActiveMerchant()
        && request.resource.data.merchantId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.quantity >= 1
        && request.resource.data.quantity <= 50;
      allow update: if isFatihAdmin()
        || (isActiveMerchant()
          && resource.data.merchantId == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.status == 'cancelled'
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'cancelledAt', 'updatedAt']));
      allow delete: if isFatihAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
